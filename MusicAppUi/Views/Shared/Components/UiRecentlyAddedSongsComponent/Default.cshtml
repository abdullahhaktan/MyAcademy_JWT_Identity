@model List<ResultRecentlyAddedDto>

<div class="row">

    <div class="col-md-6">

        <div class="heading pt-5 pb-3 d-flex">
            <div>
                <div class="text-muted">Kullanıcı</div>
                <h5 class="text-highlight">Son Eklenen</h5>
            </div>
            <span class="flex"></span>
        </div>

        <div class="row list-row list-index">

            @foreach (var item in Model.Where(x => x.IsActive))
            {
                <div class="col-12 mb-3">

                    <div class="list-item r p-3 bg-white shadow-sm rounded-lg">

                        <div class="d-flex align-items-center">

                            <div style="
                                        width:70px;
                                        height:70px;
                                        border-radius:16px;
                                        background-image:url('@item.Song.ImageUrl');
                                        background-size:cover;
                                        background-position:center;">
                            </div>

                            <div class="flex-grow-1 ml-3">
                                <div class="font-weight-bold">
                                    @item.Song.Title
                                </div>
                                <div class="text-muted small">
                                    @item.Song.Artist.Name
                                </div>
                                <div class="text-muted small">
                                    @item.Description
                                </div>
                            </div>

                            <button type="button"
                                    class="btn btn-dark btn-sm rounded-circle btn-play"
                                    style="width:45px;height:45px;"
                                    data-audio="@item.Song.FilePath"
                                    data-title="@item.Song.Title"
                                    data-artist="@item.Song.Artist.Name"
                                    data-image="@item.Song.ImageUrl">
                                ▶
                            </button>

                        </div>

                    </div>

                </div>
            }

        </div>
    </div>

    <!-- SAĞ TARAF AYNI KALDI -->
    <div class="col-md-6">
        <!-- Upcoming Events Kodun Burada Aynen Kalacak -->
    </div>

</div>