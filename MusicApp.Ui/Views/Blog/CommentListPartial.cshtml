@foreach (var comment in ViewBag.blogComments)
{
    <div class="card-body d-flex b-b">
@*         <a href="#">
            <img src="@comment.MusicUser.ImageUrl" class="avatar w-40">
        </a> *@
        <div class="mx-3 flex">
            <div class="mb-3">
                <a href="#">@comment.MusicUser.FullName</a>
                <div class="text-muted text-sm">@comment.CreatedDate.ToShortDateString()</div>
            </div>
            <div>
                <p>@comment.Description</p>
                <button class="btn btn-sm btn-white">Yanıtla</button>
            </div>
        </div>
    </div>
}